# LLM Configuration
OPENAI_API_KEY=your_openai_api_key
LLAMA_MODEL_PATH=/path/to/llama/model

# Local MongoDB
MONGODB_LOCAL_URL=mongodb://localhost:27017
MONGODB_LOCAL_DB=mind0524

# DigitalOcean MongoDB
DO_MONGODB_URL=your_digitalocean_mongodb_url
DO_MONGODB_DB=your_database_name
DO_MONGODB_USER=your_username
DO_MONGODB_PASSWORD=your_password

# Cloudflare KV
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token
CLOUDFLARE_KV_NAMESPACE_ID=your_namespace_id

# Database Configuration
DEFAULT_DB_PROVIDER=local  # local, digitalocean, or cloudflare-kv
DB_CONNECTION_TIMEOUT=5000  # milliseconds

# Security Configuration
NODE_ENV=development  # development or production
ENCRYPTION_KEY=generate_a_32_byte_key_and_store_securely
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100  # Maximum requests per window
API_RATE_LIMIT_WINDOW_MS=300000  # 5 minutes in milliseconds
API_RATE_LIMIT_MAX_REQUESTS=50  # Maximum API requests per window

# HTTPS Configuration (for production)
HTTPS_PORT=3443
SSL_KEY_PATH=/path/to/ssl/key.pem
SSL_CERT_PATH=/path/to/ssl/cert.pem

# Security Scanning
SECURITY_SCAN_SCHEDULE=0 0 * * *  # Cron schedule (daily at midnight)