{
  "name": "mind-ai-framework",
  "version": "1.0.0",
  "description": "A modern AI framework with autonomous agents, knowledge graph, and memory systems",
  "main": "src/server/index.js",
  "scripts": {
    "start": "node src/server/index.js",
    "client": "react-scripts start",
    "server": "nodemon src/server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts build",
    "test": "react-scripts test",
    "test:integration": "jest src/tests/integration",
    "test:ui": "jest src/ui/components",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "@headlessui/react": "1.7.15",
    "@heroicons/react": "2.0.18",
    "@tailwindcss/forms": "0.5.3",
    "3d-force-graph": "1.71.4",
    "autoprefixer": "10.4.14",
    "concurrently": "8.1.0",
    "express": "^4.21.2",
    "llama-node": "^0.1.6",
    "openai": "^4.103.0",
    "postcss": "8.4.24",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "6.11.2",
    "react-scripts": "^3.0.1",
    "react-update": "^0.4.4",
    "tailwindcss": "3.3.2",
    "three": "0.153.0"
  },
  "devDependencies": {
    "@babel/core": "7.22.5",
    "@babel/preset-env": "7.22.5",
    "@babel/preset-react": "7.22.5",
    "@craco/craco": "^5.9.0",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "14.0.0",
    "@testing-library/user-event": "14.4.3",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.10",
    "prettier": "2.8.8"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
