{
  "name": "mind-ai-framework",
  "version": "1.0.0",
  "description": "A modern AI framework with autonomous agents, knowledge graph, and memory systems",
  "main": "src/server/index.js",
  "scripts": {
    "start": "node src/server/index.js",
    "start:prod": "NODE_ENV=production node src/server/index.js",
    "client": "craco start",
    "server": "nodemon src/server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "craco build",
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "test": "craco test",
    "test:integration": "jest src/tests/integration",
    "test:ui": "jest src/ui/components",
    "eject": "react-scripts eject",
    "security:scan": "node scripts/security-scan.js",
    "security:audit": "npm audit --json > ./security-reports/npm-audit-$(date +%Y-%m-%d).json",
    "security:fix": "npm audit fix",
    "security:check": "npm run security:scan && npm run security:audit",
    "vault:login": "npx dotenv-vault login",
    "vault:push": "npx dotenv-vault push",
    "vault:pull": "npx dotenv-vault pull",
    "vault:open": "npx dotenv-vault open",
    "vault:build": "npx dotenv-vault build"
    "mindsdb-js-sdk": "npm install --save mindsdb-js-sdk"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20250528.0",
    "@headlessui/react": "1.7.17",
    "@heroicons/react": "2.1.1",
    "@tailwindcss/forms": "0.5.7",
    "3d-force-graph": "1.74.1",
    "autoprefixer": "10.4.17",
    "buffer": "^6.0.3",
    "concurrently": "8.2.2",
    "crypto-browserify": "^3.12.1",
    "dotenv-vault-core": "^0.7.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "llama-node": "^0.1.6",
    "mongodb": "^6.16.0",
    "openai": "^4.103.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "postcss": "8.4.35",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "6.22.3",
    "react-scripts": "^5.0.1",
    "react-update": "^0.4.4",
    "redis": "^4.6.13",
    "stream-browserify": "^3.0.0",
    "tailwindcss": "3.4.1",
    "three": "0.162.0",
    "util": "^0.12.5"
  },
  "devDependencies": {
    "@babel/core": "7.23.9",
    "@babel/preset-env": "7.23.9",
    "@babel/preset-react": "7.23.3",
    "@craco/craco": "^7.1.0",
    "@testing-library/jest-dom": "6.4.2",
    "@testing-library/react": "14.2.1",
    "@testing-library/user-event": "14.5.2",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.10",
    "prettier": "3.2.5",
    "source-map-explorer": "^2.5.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
